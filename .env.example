# Copie para .env e preencha. NUNCA suba o .env para o git.

# Chave secreta da sessão (gere uma aleatória em produção)
SECRET_KEY=troque-esta-chave-em-producao

# Login do Mestre
MESTRE_USER=mestre
MESTRE_SENHA=troque-esta-senha

# Login compartilhado dos jogadores
JOGADOR_USER=jogador
JOGADOR_SENHA=troque-esta-senha

# Assinatura (Fase 10.9 — confirmação manual)
TRIAL_DIAS=3
ASSINATURA_PRECO=R$ 5,00/mês
PIX_CHAVE=sua-chave-pix-aqui
CONTATO_PAGAMENTO=WhatsApp (00) 90000-0000

# Créditos + pagamento Pix AbacatePay (Fase 23). SEM a ABACATEPAY_API_KEY a
# compra cai no Pix manual (admin confirma no /admin/assinaturas).
CREDITO_CENTAVOS=25
COMPRA_MIN_CREDITOS=8
# Chave da conta AbacatePay. Use a de DEV (abc_dev_...) para testar com o
# botão "Simular pagamento"; troque pela de produção quando for cobrar.
ABACATEPAY_API_KEY=
# Segredo do webhook (você define no painel da AbacatePay). O webhook do app é
#   https://SEU-APP.onrender.com/api/pagamento/abacatepay/webhook?webhookSecret=ESTE-VALOR
ABACATEPAY_WEBHOOK_SECRET=

# Geração com IA (U2) — opcional. Sem a chave, os botões "✨ Gerar com IA"
# ficam ocultos e o resto do app funciona normalmente.
ANTHROPIC_API_KEY=
# Modelo: claude-haiku-4-5 (barato, padrão) ou claude-opus-4-8 (mais rico/caro)
IA_MODELO=claude-haiku-4-5
# Máximo de gerações por utilizador por dia (controle de custo)
IA_QUOTA_DIARIA=20
